{
  "version": 2,
  "framework": null,
  "installCommand": "NODE_ENV=development npm install && npm run admin:install",
  "buildCommand": "NODE_ENV=development npm run vercel-build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api/v1",
      "destination": "/api"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    }
  ]
}
