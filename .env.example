# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/youpass?retryWrites=true&w=majority&appName=App1&serverSelectionTimeoutMS=10000&connectTimeoutMS=10000"

# JWT (min 16 chars — use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=365d
JWT_SESSION_INDEFINITE=true

# OTP policy
OTP_LENGTH=6
OTP_TTL_MINUTES=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS_PER_HOUR=5
OTP_MAX_FAILED_ATTEMPTS=3
OTP_BLOCK_MINUTES=15
OTP_DELIVERY_CHANNEL=whatsapp

# Twilio WhatsApp — see docs/TWILIO_META_PRODUCTION_SETUP.md
# Local dev: true logs OTP to console + returns dev_otp_code in API
# Production: MUST be false for real WhatsApp to all numbers
TWILIO_MOCK=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Production Meta-linked sender (E.164). Sandbox: +14155238886 (join required)
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_SANDBOX_FROM=+14155238886

# Required for production sender — Content SIDs from Twilio Content Template Builder (HX...)
TWILIO_WHATSAPP_OTP_CONTENT_SID=
TWILIO_WHATSAPP_TEMPLATE_LOGIN_SID=
TWILIO_WHATSAPP_TEMPLATE_REGISTER_SID=
TWILIO_WHATSAPP_TEMPLATE_PHONE_CHANGE_SID=
TWILIO_WHATSAPP_TEMPLATE_DELETE_ACCOUNT_SID=
TWILIO_WHATSAPP_INVITATION_CONTENT_SID=

TWILIO_SMS_FROM=

# App
MIN_AGE_YEARS=18

# Cloudinary (profile photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROFILE_FOLDER=youpass/profile-photos
CLOUDINARY_DRINK_PRODUCTS_FOLDER=youpass/drink-products
CLOUDINARY_EVENT_IMAGES_FOLDER=youpass/event-images
PROFILE_PHOTO_MAX_BYTES=5242880
ADMIN_IMAGE_MAX_BYTES=5242880

# Checkout
CHECKOUT_MOCK_PAYMENT=true
KLAP_API_KEY=
KLAP_WEBHOOK_SECRET=
KLAP_CHECKOUT_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Security — reCAPTCHA
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_MIN_SCORE=0.5

ADMIN_API_KEY=youpass-dev-admin-key
ALLOW_LEGACY_CARD_INPUT=false

# Party mode — comma-separated user ids that skip venue geofence (QA / demo)
PARTY_MODE_BYPASS_USER_IDS=
