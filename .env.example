# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/youpass?retryWrites=true&w=majority&appName=App1&serverSelectionTimeoutMS=10000&connectTimeoutMS=10000"

# JWT (min 16 chars — use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=365d

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS_PER_HOUR=5
OTP_MAX_FAILED_ATTEMPTS=3
OTP_BLOCK_MINUTES=15

# Twilio WhatsApp OTP (WhatsApp Business only — no SMS)
OTP_DELIVERY_CHANNEL=whatsapp
TWILIO_MOCK=false
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WHATSAPP_SANDBOX_FROM=+14155238886

# Session: valid until manual logout (default)
JWT_SESSION_INDEFINITE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1234567890
# Production YouPass WhatsApp sender (Twilio → Messaging → WhatsApp senders). Sandbox +14155238886 shows as "Twilio".
TWILIO_WHATSAPP_FROM=+15559861808
# Required with production sender — Authentication template, variable {{1}} = OTP code
TWILIO_WHATSAPP_OTP_CONTENT_SID=
# Required for guest ticket invites — Utility template, variables {{1}}–{{4}}
TWILIO_WHATSAPP_INVITATION_CONTENT_SID=
TWILIO_MOCK=false
# Optional: approved WhatsApp template for invitations (recommended for production)
TWILIO_WHATSAPP_INVITATION_CONTENT_SID=
# Optional: reuse your OTP WhatsApp template if invite template not ready yet
TWILIO_WHATSAPP_OTP_CONTENT_SID=

# App
MIN_AGE_YEARS=18

# Cloudinary (profile photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PROFILE_FOLDER=youpass/profile-photos
PROFILE_PHOTO_MAX_BYTES=5242880

# Checkout (mock=true skips gateway; false enables Klap/Stripe async flow)
CHECKOUT_MOCK_PAYMENT=true
KLAP_API_KEY=
KLAP_WEBHOOK_SECRET=
KLAP_CHECKOUT_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Security — reCAPTCHA (optional; enable on production auth/checkout screens)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Reject raw card numbers on POST /users/me/payment-methods (use gateway tokens only)
ALLOW_LEGACY_CARD_INPUT=false
