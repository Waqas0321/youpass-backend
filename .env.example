# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (MongoDB Atlas)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/youpass?retryWrites=true&w=majority&appName=App1&serverSelectionTimeoutMS=10000&connectTimeoutMS=10000"

# JWT (min 16 chars — use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=365d

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS_PER_HOUR=5
OTP_MAX_FAILED_ATTEMPTS=3
OTP_BLOCK_MINUTES=15

# Twilio OTP delivery (sms or whatsapp)
OTP_DELIVERY_CHANNEL=whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_MOCK=true

# App
MIN_AGE_YEARS=18
