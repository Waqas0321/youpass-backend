generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthCodePurpose {
  login
  register
  change_phone
  delete_account
}

enum SentVia {
  whatsapp
  sms
}

enum UserGender {
  male
  female
  other
  prefer_not_to_say
}

enum UserCategory {
  bronze
  silver
  gold
}

enum AccountStatus {
  active
  pending_deletion
  deleted
}

enum PaymentGateway {
  klap
  stripe
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  phone               String        @unique
  countryCode         String        @map("country_code")
  preferredLanguage   String?       @map("preferred_language")
  fullName            String        @map("full_name")
  rutOrPassport       String        @map("rut_or_passport")
  email               String
  birthdate           DateTime
  gender              UserGender
  instagramUsername   String?       @map("instagram_username")
  profilePhotoUrl     String?       @map("profile_photo_url")
  category            UserCategory  @default(bronze)
  termsAcceptedAt     DateTime      @map("terms_accepted_at")
  accountStatus       AccountStatus @default(active) @map("account_status")
  deletionRequestedAt DateTime?     @map("deletion_requested_at")
  deletionScheduledAt DateTime?     @map("deletion_scheduled_at")
  pendingPhoneChange  String?       @map("pending_phone_change")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  sessions          UserSession[]
  profileCompletion UserProfileCompletion?
  authCodes         AuthCode[]             @relation("UserAuthCodes")
  eventFavorites    EventFavorite[]
  producerFollows   ProducerFollow[]
  invitations       Invitation[]       @relation("ReceivedInvitations")
  sentInvitations   Invitation[]       @relation("SentInvitations")
  ticketOrders      TicketOrder[]
  paymentMethods        UserPaymentMethod[]
  invitationPreAuths    InvitationPreAuth[]
  notificationSettings  UserNotificationSettings?
  tableLocks            TableLock[]
  waitlistEntries       WaitlistEntry[]

  @@index([email])
  @@index([countryCode])
  @@map("users")
}

model UserProfileCompletion {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  userId               String    @unique @map("user_id") @db.ObjectId
  hasPhoto             Boolean   @default(false) @map("has_photo")
  hasInstagram         Boolean   @default(false) @map("has_instagram")
  completionPercentage Int       @default(70) @map("completion_percentage")
  bannerDismissedAt    DateTime? @map("banner_dismissed_at")
  bannerShowAgainAt    DateTime? @map("banner_show_again_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile_completion")
}

// ─── YouAccess (Auth) ────────────────────────────────────────────────────────

model AuthCode {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  phone            String
  codeHash         String          @map("code_hash")
  purpose          AuthCodePurpose
  countryCode      String          @map("country_code")
  expiresAt        DateTime        @map("expires_at")
  usedAt           DateTime?       @map("used_at")
  sentVia          SentVia         @default(whatsapp) @map("sent_via")
  whatsappTemplate String          @map("whatsapp_template")
  userId           String?         @map("user_id") @db.ObjectId
  createdAt        DateTime        @default(now()) @map("created_at")

  user     User?         @relation("UserAuthCodes", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attempts AuthAttempt[]

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
  @@map("auth_codes")
}

model AuthAttempt {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  phone         String
  codeId        String?  @map("code_id") @db.ObjectId
  wasSuccessful Boolean  @map("was_successful")
  deviceInfo    Json?    @map("device_info")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([phone, createdAt])
  @@map("auth_attempts")
}

model AuthRateLimit {
  phone              String    @id @map("_id")
  resendCountHour    Int       @default(0) @map("resend_count_hour")
  resendCountResetAt DateTime? @map("resend_count_reset_at")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  blockedUntil       DateTime? @map("blocked_until")
  lastResendAt       DateTime? @map("last_resend_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("auth_rate_limits")
}

model UserSession {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @map("user_id") @db.ObjectId
  tokenHash      String    @unique @map("token_hash")
  deviceInfo     Json?     @map("device_info")
  ipAddress      String?   @map("ip_address")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model AnalyticsEvent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @map("user_id") @db.ObjectId
  eventName  String   @map("event_name")
  properties Json?
  deviceInfo Json?    @map("device_info")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

// ─── Multi-country config ────────────────────────────────────────────────────

model Country {
  code             String         @id @map("_id")
  name             String
  dialCode         String         @map("dial_code")
  phoneHint        String?        @map("phone_hint")
  flagEmoji        String         @map("flag_emoji")
  currencyCode     String         @map("currency_code")
  currencySymbol   String         @map("currency_symbol")
  currencyDecimals Int            @default(2) @map("currency_decimals")
  languageCode     String         @map("language_code")
  paymentGateway   PaymentGateway @map("payment_gateway")
  timezone         String
  isActive         Boolean        @default(true) @map("is_active")
  displayOrder     Int            @default(0) @map("display_order")

  @@map("countries")
}

enum BannerTapActionType {
  event_detail
  external_url
  promoter_page
  landing_page
}

// ─── Events (YouHome) ────────────────────────────────────────────────────────

enum EventStatus {
  draft
  published
  cancelled
}

enum VenueKind {
  stadium
  club_nightclub
  theatre
  open_air
  events_centre
  bar_restaurant
  other
}

model EventType {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  slug         String  @unique
  name         String
  icon         String?
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")

  events Event[]

  @@map("event_types")
}

model Event {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  startsAt      DateTime    @map("starts_at")
  endsAt        DateTime?   @map("ends_at")
  entryTimeLabel String?    @map("entry_time_label")
  venueName     String      @map("venue_name")
  city          String
  zone          String?
  latitude      Float?
  longitude     Float?
  countryCode   String      @map("country_code")
  producerName  String?     @map("producer_name")
  venueKind     VenueKind?  @map("venue_kind")
  minPrice      Float?      @map("min_price")
  currencyCode  String?     @map("currency_code")
  imageUrl      String?     @map("image_url")
  eventTypeId   String      @map("event_type_id") @db.ObjectId
  isFeatured    Boolean     @default(false) @map("is_featured")
  featuredOrder Int         @default(0) @map("featured_order")
  status        EventStatus @default(draft)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  eventType EventType       @relation(fields: [eventTypeId], references: [id])
  favorites         EventFavorite[]
  invitations       Invitation[]
  ticketOrders      TicketOrder[]
  ticketOfferings   EventTicketOffering[]
  venueLayout       EventVenueLayout?
  homeBannerSlides  HomeBannerSlide[]
  invitationSettings InvitationSettings?
  freedSlots        FreedInvitationSlot[]
  waitlistEntries   WaitlistEntry[]
  waitlistOffers    WaitlistOffer[]

  @@index([countryCode, status, startsAt])
  @@index([isFeatured, featuredOrder])
  @@index([eventTypeId])
  @@index([city])
  @@index([venueKind])
  @@map("events")
}

model HomeBannerSlide {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  title           String?
  subtitle        String?
  imageUrl        String              @map("image_url")
  tapActionType   BannerTapActionType @default(event_detail) @map("tap_action_type")
  eventId         String?             @map("event_id") @db.ObjectId
  externalUrl     String?             @map("external_url")
  producerId      String?             @map("producer_id") @db.ObjectId
  landingSlug     String?             @map("landing_slug")
  displayStartsAt DateTime            @map("display_starts_at")
  displayEndsAt   DateTime            @map("display_ends_at")
  countryCodes    String[]            @default([]) @map("country_codes")
  cities          String[]            @default([]) @map("cities")
  userCategories  UserCategory[]      @default([]) @map("user_categories")
  priority        Int                 @default(0)
  aspectRatio     String              @default("16:9") @map("aspect_ratio")
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  event    Event?    @relation(fields: [eventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  producer Producer? @relation(fields: [producerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([isActive, priority])
  @@index([displayStartsAt, displayEndsAt])
  @@map("home_banner_slides")
}

model EventListingConfig {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  configKey      String   @unique @default("default") @map("config_key")
  dateWeight     Float    @default(0.5) @map("date_weight")
  locationWeight Float    @default(0.3) @map("location_weight")
  featuredWeight Float    @default(0.2) @map("featured_weight")
  pageSize       Int      @default(20) @map("page_size")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("event_listing_config")
}

model InvitationConfig {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  configKey  String   @unique @default("default") @map("config_key")
  expiryDays Int      @default(3) @map("expiry_days")
  enableFreeInvitations        Boolean @default(true) @map("enable_free_invitations")
  enableGuaranteedPass         Boolean @default(true) @map("enable_guaranteed_pass")
  enableDiscountedInvitations  Boolean @default(true) @map("enable_discounted_invitations")
  freeCancellationDays         Int     @default(1) @map("free_cancellation_days")
  guaranteedCancellationDays   Int     @default(3) @map("guaranteed_cancellation_days")
  discountedCancellationDays   Int     @default(1) @map("discounted_cancellation_days")
  guaranteedPassReminderTemplates Json? @map("gp_reminder_templates")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("invitation_config")
}

enum TicketOfferingSection {
  general
  vip
}

enum VenueZoneKind {
  vip_table_zone
  vip_premium_zone
  stage
  general_floor
}

enum VenueZoneStatus {
  available
  premium
  sold
}

enum VenueTableStatus {
  available
  sold
  premium
}

enum TableLockStatus {
  ACTIVE
  EXPIRED
  CONSUMED
}

model EventTicketOffering {
  id           String                @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String                @map("event_id") @db.ObjectId
  slug         String
  label        String
  description  String?
  section      TicketOfferingSection
  price        Float
  currency     String                @default("CLP")
  badgeLabel   String?               @map("badge_label")
  displayOrder Int                   @default(0) @map("display_order")
  maxPerOrder  Int                   @default(10) @map("max_per_order")
  stockQuantity Int?                 @map("stock_quantity")
  soldQuantity  Int                   @default(0) @map("sold_quantity")
  saleStartsAt  DateTime?             @map("sale_starts_at")
  saleEndsAt    DateTime?             @map("sale_ends_at")
  mapsToTier   InvitationTier        @map("maps_to_tier")
  mapsToType   TicketCatalogType     @map("maps_to_type")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, slug])
  @@index([eventId, isActive])
  @@map("event_ticket_offerings")
}

model EventVenueLayout {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId          String   @unique @map("event_id") @db.ObjectId
  venueName        String   @map("venue_name")
  widthMeters      Float    @map("width_meters")
  heightMeters     Float    @map("height_meters")
  tableLockMinutes Int      @default(10) @map("table_lock_minutes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zones VenueZone[]

  @@map("event_venue_layouts")
}

model VenueZone {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  layoutId         String          @map("layout_id") @db.ObjectId
  externalId       String          @map("external_id")
  name             String
  kind             VenueZoneKind
  status           VenueZoneStatus @default(available)
  positionX        Float           @map("position_x")
  positionY        Float           @map("position_y")
  sizeWidth        Float           @map("size_width")
  sizeHeight       Float           @map("size_height")
  color            String
  capacityPerTable Int?            @map("capacity_per_table")
  isSelectable     Boolean         @default(true) @map("is_selectable")
  displayOrder     Int             @default(0) @map("display_order")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  layout EventVenueLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  tables VenueTable[]

  @@unique([layoutId, externalId])
  @@index([layoutId])
  @@map("venue_zones")
}

model VenueTable {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  zoneId       String           @map("zone_id") @db.ObjectId
  externalId   String           @map("external_id")
  number       Int
  label        String
  status       VenueTableStatus @default(available)
  positionX    Float            @map("position_x")
  positionY    Float            @map("position_y")
  price        Float
  currency     String           @default("CLP")
  capacity     Int              @default(10)
  bottleCount  Int              @default(0) @map("bottle_count")
  voucherCount Int              @default(0) @map("voucher_count")
  isPremium    Boolean          @default(false) @map("is_premium")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  zone  VenueZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locks TableLock[]

  @@unique([zoneId, label])
  @@unique([zoneId, externalId])
  @@index([zoneId, status])
  @@map("venue_tables")
}

model TableLock {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  tableId   String          @map("table_id") @db.ObjectId
  userId    String          @map("user_id") @db.ObjectId
  eventId   String          @map("event_id") @db.ObjectId
  status    TableLockStatus @default(ACTIVE)
  expiresAt DateTime        @map("expires_at")
  createdAt DateTime        @default(now()) @map("created_at")

  table VenueTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tableId, expiresAt])
  @@index([userId, eventId])
  @@index([status, expiresAt])
  @@map("table_locks")
}

model EventFavorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  eventId   String   @map("event_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@map("event_favorites")
}

// ─── Invitations ─────────────────────────────────────────────────────────────

enum TicketCatalogType {
  courtesy
  free
  general
  vip
  vip_table
  discounted
}

/** Section 14.7 — invitation product type stored on invitations.type */
enum InvitationProductType {
  free
  guaranteed
  discount
}

/** Section 14.7 — invitation lifecycle status stored on invitations.status */
enum InvitationStatus {
  sent
  viewed
  accepted
  rejected
  expired
  canceled
  validated
  charged
  failed
}

enum InvitationPreAuthStatus {
  pre_authorized
  released
  captured
  failed
}

enum InvitationReminderType {
  seven_days  @map("7_days")
  five_days   @map("5_days")
  deadline
  twenty_four_h @map("24h")
  three_h       @map("3h")
}

enum InvitationReminderChannel {
  whatsapp
  push
  email
}

enum InvitationReminderStatus {
  pending
  sent
  failed
}

enum InvitationTier {
  general
  vip
}

enum InvitationSource {
  producer
  guest
}

enum TicketOrderStatus {
  pending_payment
  paid
  cancelled
  refunded
}

enum TicketSlotStatus {
  available
  assigned
  claimed
  owner
}

model Producer {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  logoUrl       String?  @map("logo_url")
  description   String?
  coverageLabel String?  @map("coverage_label")
  followerCount Int      @default(0) @map("follower_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  followers         ProducerFollow[]
  invitations       Invitation[]
  homeBannerSlides  HomeBannerSlide[]
  freedSlots        FreedInvitationSlot[]

  @@map("producers")
}

model ProducerFollow {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @map("user_id") @db.ObjectId
  producerId String   @map("producer_id") @db.ObjectId
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  producer Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@unique([userId, producerId])
  @@index([userId])
  @@index([producerId])
  @@map("producer_follows")
}

model ProducerPresaleConfig {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  configKey          String   @unique @default("default") @map("config_key")
  presaleWindowHours Int      @default(24) @map("presale_window_hours")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("producer_presale_config")
}

model Invitation {
  id                 String                @id @default(auto()) @map("_id") @db.ObjectId
  eventId            String                @map("event_id") @db.ObjectId
  producerId         String                @map("producer_id") @db.ObjectId
  recipientPhone     String                @map("recipient_phone")
  recipientUserId    String?               @map("recipient_user_id") @db.ObjectId
  type               InvitationProductType
  assignedSlot       String                @map("assigned_slot")
  entryValue         Float                 @map("entry_value")
  discountPercentage Int?                  @map("discount_percentage")
  amountToPay        Float                 @map("amount_to_pay")
  cancellationDeadline DateTime            @map("cancellation_deadline")
  status             InvitationStatus      @default(sent)
  sentAt             DateTime              @default(now()) @map("sent_at")
  viewedAt           DateTime?             @map("viewed_at")
  respondedAt        DateTime?             @map("responded_at")
  canceledAt         DateTime?             @map("canceled_at")
  customMessage      String?               @map("custom_message")
  // Guest-ticket flow extensions (not in 14.7 spec but required by existing features)
  inviterUserId      String?               @map("inviter_user_id") @db.ObjectId
  source             InvitationSource      @default(producer)
  recipientName      String?               @map("recipient_name")
  claimToken         String?               @map("claim_token")
  tier               InvitationTier        @default(general)
  chargeCurrency     String?               @map("charge_currency")
  expiresAt          DateTime?             @map("expires_at")
  whatsappSentAt     DateTime?             @map("whatsapp_sent_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  event     Event                @relation(fields: [eventId], references: [id])
  producer  Producer             @relation(fields: [producerId], references: [id])
  recipient User?                @relation("ReceivedInvitations", fields: [recipientUserId], references: [id], onDelete: Cascade)
  inviter   User?                @relation("SentInvitations", fields: [inviterUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket    InvitationTicket?
  auditLogs InvitationAuditLog[]
  preAuth   InvitationPreAuth?
  reminders InvitationReminder[]

  @@index([recipientUserId, status])
  @@index([recipientPhone, status])
  @@index([inviterUserId])
  @@index([claimToken])
  @@index([eventId])
  @@map("invitations")
}

model InvitationPreAuth {
  id                    String                  @id @default(auto()) @map("_id") @db.ObjectId
  invitationId          String                  @unique @map("invitation_id") @db.ObjectId
  userId                String                  @map("user_id") @db.ObjectId
  cardId                String                  @map("card_id") @db.ObjectId
  amount                Float
  gateway               PaymentGateway
  gatewayTransactionId  String                  @map("gateway_transaction_id")
  status                InvitationPreAuthStatus @default(pre_authorized)
  expiresAt             DateTime                @map("expires_at")
  createdAt             DateTime                @default(now()) @map("created_at")
  capturedAt            DateTime?               @map("captured_at")
  releasedAt            DateTime?               @map("released_at")

  invitation Invitation        @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       UserPaymentMethod @relation(fields: [cardId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([status, expiresAt])
  @@map("invitation_pre_auths")
}

model InvitationReminder {
  id           String                    @id @default(auto()) @map("_id") @db.ObjectId
  invitationId String                    @map("invitation_id") @db.ObjectId
  reminderType InvitationReminderType    @map("reminder_type")
  scheduledAt  DateTime                  @map("scheduled_at")
  sentAt       DateTime?                 @map("sent_at")
  channel      InvitationReminderChannel @default(whatsapp)
  status       InvitationReminderStatus  @default(pending)

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@unique([invitationId, reminderType])
  @@index([status, scheduledAt])
  @@map("invitation_reminders")
}

model InvitationAuditLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  invitationId String?  @map("invitation_id") @db.ObjectId
  actorUserId  String?  @map("actor_user_id") @db.ObjectId
  actorType    String   @map("actor_type")
  action       String
  result       String
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  invitation Invitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  @@index([invitationId])
  @@index([createdAt])
  @@map("invitation_audit_logs")
}

model FreedInvitationSlot {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String    @map("event_id") @db.ObjectId
  producerId   String    @map("producer_id") @db.ObjectId
  slotLabel    String    @map("slot_label")
  invitationId String?   @map("invitation_id") @db.ObjectId
  releasedAt   DateTime  @default(now()) @map("released_at")
  reinvitedAt  DateTime? @map("reinvited_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id])
  producer Producer @relation(fields: [producerId], references: [id])

  @@index([producerId, releasedAt])
  @@index([eventId])
  @@map("freed_invitation_slots")
}

enum WaitlistEntryStatus {
  waiting
  offered
  claimed
  left
  expired_removed
}

enum WaitlistOfferStatus {
  active
  claimed
  expired
  canceled
}

model WaitlistEntry {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String              @map("event_id") @db.ObjectId
  userId    String              @map("user_id") @db.ObjectId
  status    WaitlistEntryStatus @default(waiting)
  joinedAt  DateTime            @default(now()) @map("joined_at")
  leftAt    DateTime?           @map("left_at")
  removedAt DateTime?           @map("removed_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  event  Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers WaitlistOffer[]

  @@unique([eventId, userId])
  @@index([eventId, status, joinedAt])
  @@index([userId, status])
  @@map("waitlist_entries")
}

model WaitlistOffer {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  eventId         String              @map("event_id") @db.ObjectId
  userId          String              @map("user_id") @db.ObjectId
  waitlistEntryId String              @map("waitlist_entry_id") @db.ObjectId
  freedSlotId     String?             @map("freed_slot_id") @db.ObjectId
  slotLabel       String              @map("slot_label")
  producerId      String              @map("producer_id") @db.ObjectId
  invitationId    String?             @map("invitation_id") @db.ObjectId
  status          WaitlistOfferStatus @default(active)
  offeredAt       DateTime            @default(now()) @map("offered_at")
  expiresAt       DateTime            @map("expires_at")
  reminderSentAt  DateTime?           @map("reminder_sent_at")
  claimedAt       DateTime?           @map("claimed_at")
  expiredAt       DateTime?           @map("expired_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  waitlistEntry WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([eventId, status])
  @@index([userId, status])
  @@map("waitlist_offers")
}

model InvitationSettings {
  eventId                     String   @id @map("_id") @db.ObjectId
  allowFree                   Boolean  @default(true) @map("allow_free")
  allowGuaranteed             Boolean  @default(true) @map("allow_guaranteed")
  allowDiscount               Boolean  @default(true) @map("allow_discount")
  freeCancellationDays        Int      @default(7) @map("free_cancellation_days")
  guaranteedCancellationDays  Int      @default(3) @map("guaranteed_cancellation_days")
  discountCancellationDays    Int      @default(2) @map("discount_cancellation_days")
  discountPercentage          Int?     @map("discount_percentage")
  enableWaitingList           Boolean  @default(true) @map("enable_waiting_list")
  enableManualReinvitation    Boolean  @default(true) @map("enable_manual_reinvitation")
  waitlistOfferHours          Int      @default(4) @map("waitlist_offer_hours")
  courtesySlotsTotal          Int      @default(0) @map("courtesy_slots_total")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("invitation_settings")
}

model TicketOrder {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  buyerUserId       String            @map("buyer_user_id") @db.ObjectId
  eventId           String            @map("event_id") @db.ObjectId
  quantity          Int
  tier              InvitationTier
  type              TicketCatalogType @default(general)
  unitPrice         Float             @map("unit_price")
  subtotalAmount    Float             @default(0) @map("subtotal_amount")
  serviceFeeRate    Float             @default(0.05) @map("service_fee_rate")
  serviceFeeAmount  Float             @default(0) @map("service_fee_amount")
  totalAmount       Float             @map("total_amount")
  currency          String            @default("CLP")
  status            TicketOrderStatus @default(paid)
  paymentReference  String?           @map("payment_reference")
  venueTableId      String?           @map("venue_table_id") @db.ObjectId
  venueZoneId       String?           @map("venue_zone_id") @db.ObjectId
  ticketOfferingId  String?           @map("ticket_offering_id") @db.ObjectId
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  buyer User         @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  event Event        @relation(fields: [eventId], references: [id])
  slots TicketSlot[]

  @@index([buyerUserId, status])
  @@index([eventId])
  @@map("ticket_orders")
}

model TicketSlot {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String           @map("order_id") @db.ObjectId
  slotNumber        Int              @map("slot_number")
  status            TicketSlotStatus @default(available)
  guestName         String?          @map("guest_name")
  guestPhone        String?          @map("guest_phone")
  guestCountryCode  String?          @map("guest_country_code")
  invitationId      String?          @map("invitation_id") @db.ObjectId
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  order      TicketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, slotNumber])
  @@index([orderId, status])
  @@index([invitationId])
  @@map("ticket_slots")
}

model InvitationTicket {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  invitationId     String    @unique @map("invitation_id") @db.ObjectId
  manualEntryId    String    @map("manual_entry_id")
  qrPayload        String    @map("qr_payload")
  unlockAt         DateTime  @map("unlock_at")
  validatedAt      DateTime? @map("validated_at")
  consumptionCount Int?      @map("consumption_count")
  stayMinutes      Int?      @map("stay_minutes")
  createdAt        DateTime  @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("invitation_tickets")
}

model UserPaymentMethod {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  userId           String          @map("user_id") @db.ObjectId
  providerToken    String          @map("provider_token")
