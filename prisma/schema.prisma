generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthCodePurpose {
  login
  register
  change_phone
  delete_account
}

enum SentVia {
  whatsapp
  sms
}

enum UserGender {
  male
  female
  other
  prefer_not_to_say
}

enum UserCategory {
  bronze
  silver
  gold
}

enum AccountStatus {
  active
  pending_deletion
  deleted
}

enum PaymentGateway {
  klap
  stripe
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  phone               String        @unique
  countryCode         String        @map("country_code")
  fullName            String        @map("full_name")
  rutOrPassport       String        @map("rut_or_passport")
  email               String
  birthdate           DateTime
  gender              UserGender
  instagramUsername   String?       @map("instagram_username")
  profilePhotoUrl     String?       @map("profile_photo_url")
  category            UserCategory  @default(bronze)
  termsAcceptedAt     DateTime      @map("terms_accepted_at")
  accountStatus       AccountStatus @default(active) @map("account_status")
  deletionRequestedAt DateTime?     @map("deletion_requested_at")
  deletionScheduledAt DateTime?     @map("deletion_scheduled_at")
  pendingPhoneChange  String?       @map("pending_phone_change")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  sessions          UserSession[]
  profileCompletion UserProfileCompletion?
  authCodes         AuthCode[]             @relation("UserAuthCodes")

  @@index([email])
  @@index([countryCode])
  @@map("users")
}

model UserProfileCompletion {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  userId               String    @unique @map("user_id") @db.ObjectId
  hasPhoto             Boolean   @default(false) @map("has_photo")
  hasInstagram         Boolean   @default(false) @map("has_instagram")
  completionPercentage Int       @default(70) @map("completion_percentage")
  bannerDismissedAt    DateTime? @map("banner_dismissed_at")
  bannerShowAgainAt    DateTime? @map("banner_show_again_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile_completion")
}

// ─── YouAccess (Auth) ────────────────────────────────────────────────────────

model AuthCode {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  phone            String
  codeHash         String          @map("code_hash")
  purpose          AuthCodePurpose
  countryCode      String          @map("country_code")
  expiresAt        DateTime        @map("expires_at")
  usedAt           DateTime?       @map("used_at")
  sentVia          SentVia         @default(whatsapp) @map("sent_via")
  whatsappTemplate String          @map("whatsapp_template")
  userId           String?         @map("user_id") @db.ObjectId
  createdAt        DateTime        @default(now()) @map("created_at")

  user     User?         @relation("UserAuthCodes", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attempts AuthAttempt[]

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
  @@map("auth_codes")
}

model AuthAttempt {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  phone         String
  codeId        String?  @map("code_id") @db.ObjectId
  wasSuccessful Boolean  @map("was_successful")
  deviceInfo    Json?    @map("device_info")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([phone, createdAt])
  @@map("auth_attempts")
}

model AuthRateLimit {
  phone              String    @id @map("_id")
  resendCountHour    Int       @default(0) @map("resend_count_hour")
  resendCountResetAt DateTime? @map("resend_count_reset_at")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  blockedUntil       DateTime? @map("blocked_until")
  lastResendAt       DateTime? @map("last_resend_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("auth_rate_limits")
}

model UserSession {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @map("user_id") @db.ObjectId
  tokenHash      String    @unique @map("token_hash")
  deviceInfo     Json?     @map("device_info")
  ipAddress      String?   @map("ip_address")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ─── Multi-country config ────────────────────────────────────────────────────

model Country {
  code             String         @id @map("_id")
  name             String
  dialCode         String         @map("dial_code")
  flagEmoji        String         @map("flag_emoji")
  currencyCode     String         @map("currency_code")
  currencySymbol   String         @map("currency_symbol")
  currencyDecimals Int            @default(2) @map("currency_decimals")
  languageCode     String         @map("language_code")
  paymentGateway   PaymentGateway @map("payment_gateway")
  timezone         String
  isActive         Boolean        @default(true) @map("is_active")
  displayOrder     Int            @default(0) @map("display_order")

  @@map("countries")
}
