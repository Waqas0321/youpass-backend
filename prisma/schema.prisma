generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthCodePurpose {
  login
  register
  change_phone
  delete_account
}

enum SentVia {
  whatsapp
  sms
}

enum UserGender {
  male
  female
  other
  prefer_not_to_say
}

enum UserCategory {
  bronze
  silver
  gold
}

enum AccountStatus {
  active
  pending_deletion
  deleted
}

enum PaymentGateway {
  klap
  stripe
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  phone               String        @unique
  countryCode         String        @map("country_code")
  preferredLanguage   String?       @map("preferred_language")
  fullName            String        @map("full_name")
  rutOrPassport       String        @map("rut_or_passport")
  email               String
  birthdate           DateTime
  gender              UserGender
  instagramUsername   String?       @map("instagram_username")
  profilePhotoUrl     String?       @map("profile_photo_url")
  category            UserCategory  @default(bronze)
  termsAcceptedAt     DateTime      @map("terms_accepted_at")
  accountStatus       AccountStatus @default(active) @map("account_status")
  deletionRequestedAt DateTime?     @map("deletion_requested_at")
  deletionScheduledAt DateTime?     @map("deletion_scheduled_at")
  pendingPhoneChange  String?       @map("pending_phone_change")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  sessions          UserSession[]
  profileCompletion UserProfileCompletion?
  authCodes         AuthCode[]             @relation("UserAuthCodes")
  eventFavorites    EventFavorite[]
  invitations       Invitation[]       @relation("ReceivedInvitations")
  sentInvitations   Invitation[]       @relation("SentInvitations")
  ticketOrders      TicketOrder[]
  paymentMethods    UserPaymentMethod[]
  tableLocks        TableLock[]

  @@index([email])
  @@index([countryCode])
  @@map("users")
}

model UserProfileCompletion {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  userId               String    @unique @map("user_id") @db.ObjectId
  hasPhoto             Boolean   @default(false) @map("has_photo")
  hasInstagram         Boolean   @default(false) @map("has_instagram")
  completionPercentage Int       @default(70) @map("completion_percentage")
  bannerDismissedAt    DateTime? @map("banner_dismissed_at")
  bannerShowAgainAt    DateTime? @map("banner_show_again_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile_completion")
}

// ─── YouAccess (Auth) ────────────────────────────────────────────────────────

model AuthCode {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  phone            String
  codeHash         String          @map("code_hash")
  purpose          AuthCodePurpose
  countryCode      String          @map("country_code")
  expiresAt        DateTime        @map("expires_at")
  usedAt           DateTime?       @map("used_at")
  sentVia          SentVia         @default(whatsapp) @map("sent_via")
  whatsappTemplate String          @map("whatsapp_template")
  userId           String?         @map("user_id") @db.ObjectId
  createdAt        DateTime        @default(now()) @map("created_at")

  user     User?         @relation("UserAuthCodes", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attempts AuthAttempt[]

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
  @@map("auth_codes")
}

model AuthAttempt {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  phone         String
  codeId        String?  @map("code_id") @db.ObjectId
  wasSuccessful Boolean  @map("was_successful")
  deviceInfo    Json?    @map("device_info")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  code AuthCode? @relation(fields: [codeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([phone, createdAt])
  @@map("auth_attempts")
}

model AuthRateLimit {
  phone              String    @id @map("_id")
  resendCountHour    Int       @default(0) @map("resend_count_hour")
  resendCountResetAt DateTime? @map("resend_count_reset_at")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  blockedUntil       DateTime? @map("blocked_until")
  lastResendAt       DateTime? @map("last_resend_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("auth_rate_limits")
}

model UserSession {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @map("user_id") @db.ObjectId
  tokenHash      String    @unique @map("token_hash")
  deviceInfo     Json?     @map("device_info")
  ipAddress      String?   @map("ip_address")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model AnalyticsEvent {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @map("user_id") @db.ObjectId
  eventName  String   @map("event_name")
  properties Json?
  deviceInfo Json?    @map("device_info")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

// ─── Multi-country config ────────────────────────────────────────────────────

model Country {
  code             String         @id @map("_id")
  name             String
  dialCode         String         @map("dial_code")
  phoneHint        String?        @map("phone_hint")
  flagEmoji        String         @map("flag_emoji")
  currencyCode     String         @map("currency_code")
  currencySymbol   String         @map("currency_symbol")
  currencyDecimals Int            @default(2) @map("currency_decimals")
  languageCode     String         @map("language_code")
  paymentGateway   PaymentGateway @map("payment_gateway")
  timezone         String
  isActive         Boolean        @default(true) @map("is_active")
  displayOrder     Int            @default(0) @map("display_order")

  @@map("countries")
}

// ─── Events (YouHome) ────────────────────────────────────────────────────────

enum EventStatus {
  draft
  published
  cancelled
}

model EventType {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  slug         String  @unique
  name         String
  icon         String?
  displayOrder Int     @default(0) @map("display_order")
  isActive     Boolean @default(true) @map("is_active")

  events Event[]

  @@map("event_types")
}

model Event {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  startsAt      DateTime    @map("starts_at")
  venueName     String      @map("venue_name")
  city          String
  countryCode   String      @map("country_code")
  imageUrl      String?     @map("image_url")
  eventTypeId   String      @map("event_type_id") @db.ObjectId
  isFeatured    Boolean     @default(false) @map("is_featured")
  featuredOrder Int         @default(0) @map("featured_order")
  status        EventStatus @default(draft)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  eventType EventType       @relation(fields: [eventTypeId], references: [id])
  favorites         EventFavorite[]
  invitations       Invitation[]
  ticketOrders      TicketOrder[]
  ticketOfferings   EventTicketOffering[]
  venueLayout       EventVenueLayout?

  @@index([countryCode, status, startsAt])
  @@index([isFeatured, featuredOrder])
  @@index([eventTypeId])
  @@map("events")
}

enum TicketOfferingSection {
  general
  vip
}

enum VenueZoneKind {
  vip_table_zone
  vip_premium_zone
  stage
  general_floor
}

enum VenueZoneStatus {
  available
  premium
  sold
}

enum VenueTableStatus {
  available
  sold
  premium
}

model EventTicketOffering {
  id           String                @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String                @map("event_id") @db.ObjectId
  slug         String
  label        String
  description  String?
  section      TicketOfferingSection
  price        Float
  currency     String                @default("CLP")
  badgeLabel   String?               @map("badge_label")
  displayOrder Int                   @default(0) @map("display_order")
  maxPerOrder  Int                   @default(10) @map("max_per_order")
  mapsToTier   InvitationTier        @map("maps_to_tier")
  mapsToType   InvitationType        @map("maps_to_type")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, slug])
  @@index([eventId, isActive])
  @@map("event_ticket_offerings")
}

model EventVenueLayout {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String   @unique @map("event_id") @db.ObjectId
  venueName    String   @map("venue_name")
  widthMeters  Float    @map("width_meters")
  heightMeters Float    @map("height_meters")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zones VenueZone[]

  @@map("event_venue_layouts")
}

model VenueZone {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  layoutId         String          @map("layout_id") @db.ObjectId
  externalId       String          @map("external_id")
  name             String
  kind             VenueZoneKind
  status           VenueZoneStatus @default(available)
  positionX        Float           @map("position_x")
  positionY        Float           @map("position_y")
  sizeWidth        Float           @map("size_width")
  sizeHeight       Float           @map("size_height")
  color            String
  capacityPerTable Int?            @map("capacity_per_table")
  isSelectable     Boolean         @default(true) @map("is_selectable")
  displayOrder     Int             @default(0) @map("display_order")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  layout EventVenueLayout @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  tables VenueTable[]

  @@unique([layoutId, externalId])
  @@index([layoutId])
  @@map("venue_zones")
}

model VenueTable {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  zoneId       String           @map("zone_id") @db.ObjectId
  externalId   String           @map("external_id")
  number       Int
  label        String
  status       VenueTableStatus @default(available)
  positionX    Float            @map("position_x")
  positionY    Float            @map("position_y")
  price        Float
  currency     String           @default("CLP")
  capacity     Int              @default(10)
  bottleCount  Int              @default(0) @map("bottle_count")
  voucherCount Int              @default(0) @map("voucher_count")
  isPremium    Boolean          @default(false) @map("is_premium")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  zone  VenueZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  locks TableLock[]

  @@unique([zoneId, label])
  @@unique([zoneId, externalId])
  @@index([zoneId, status])
  @@map("venue_tables")
}

model TableLock {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tableId   String   @map("table_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  eventId   String   @map("event_id") @db.ObjectId
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  table VenueTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tableId, expiresAt])
  @@index([userId, eventId])
  @@map("table_locks")
}

model EventFavorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @map("user_id") @db.ObjectId
  eventId   String   @map("event_id") @db.ObjectId
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@map("event_favorites")
}

// ─── Invitations ─────────────────────────────────────────────────────────────

enum InvitationType {
  courtesy
  free
  general
  vip
  vip_table
  discounted
}

enum InvitationTier {
  general
  vip
}

enum InvitationStatus {
  pending
  confirmed
  rejected
  expired
  canceled
  validated
}

enum InvitationSource {
  producer
  guest
}

enum TicketOrderStatus {
  pending_payment
  paid
  cancelled
  refunded
}

enum TicketSlotStatus {
  available
  assigned
  claimed
  owner
}

model Producer {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  logoUrl     String?      @map("logo_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  invitations Invitation[]

  @@map("producers")
}

model Invitation {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  eventId               String           @map("event_id") @db.ObjectId
  producerId            String           @map("producer_id") @db.ObjectId
  recipientUserId       String?          @map("recipient_user_id") @db.ObjectId
  inviterUserId         String?          @map("inviter_user_id") @db.ObjectId
  source                InvitationSource @default(producer)
  recipientPhone        String?          @map("recipient_phone")
  recipientName         String?          @map("recipient_name")
  claimToken            String?          @map("claim_token")
  whatsappSentAt        DateTime?        @map("whatsapp_sent_at")
  type                  InvitationType
  tier                  InvitationTier
  status                InvitationStatus @default(pending)
  assignedSlot          String?          @map("assigned_slot")
  customMessage         String?          @map("custom_message")
  chargeAmount          Float?           @map("charge_amount")
  chargeCurrency        String?          @map("charge_currency")
  requiresPaymentMethod Boolean          @default(false) @map("requires_payment_method")
  termsAcceptedRequired Boolean          @default(false) @map("terms_accepted_required")
  cancellationDeadline  DateTime?        @map("cancellation_deadline")
  viewedAt              DateTime?        @map("viewed_at")
  respondedAt           DateTime?        @map("responded_at")
  sentAt                DateTime         @default(now()) @map("sent_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  event     Event              @relation(fields: [eventId], references: [id])
  producer  Producer           @relation(fields: [producerId], references: [id])
  recipient User?              @relation("ReceivedInvitations", fields: [recipientUserId], references: [id], onDelete: Cascade)
  inviter   User?              @relation("SentInvitations", fields: [inviterUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket    InvitationTicket?

  @@index([recipientUserId, status])
  @@index([recipientPhone, status])
  @@index([inviterUserId])
  @@index([claimToken])
  @@index([eventId])
  @@map("invitations")
}

model TicketOrder {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  buyerUserId       String            @map("buyer_user_id") @db.ObjectId
  eventId           String            @map("event_id") @db.ObjectId
  quantity          Int
  tier              InvitationTier
  type              InvitationType    @default(general)
  unitPrice         Float             @map("unit_price")
  subtotalAmount    Float             @default(0) @map("subtotal_amount")
  serviceFeeRate    Float             @default(0.05) @map("service_fee_rate")
  serviceFeeAmount  Float             @default(0) @map("service_fee_amount")
  totalAmount       Float             @map("total_amount")
  currency          String            @default("CLP")
  status            TicketOrderStatus @default(paid)
  paymentReference  String?           @map("payment_reference")
  venueTableId      String?           @map("venue_table_id") @db.ObjectId
  venueZoneId       String?           @map("venue_zone_id") @db.ObjectId
  ticketOfferingId  String?           @map("ticket_offering_id") @db.ObjectId
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  buyer User         @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  event Event        @relation(fields: [eventId], references: [id])
  slots TicketSlot[]

  @@index([buyerUserId, status])
  @@index([eventId])
  @@map("ticket_orders")
}

model TicketSlot {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String           @map("order_id") @db.ObjectId
  slotNumber        Int              @map("slot_number")
  status            TicketSlotStatus @default(available)
  guestName         String?          @map("guest_name")
  guestPhone        String?          @map("guest_phone")
  guestCountryCode  String?          @map("guest_country_code")
  invitationId      String?          @map("invitation_id") @db.ObjectId
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  order      TicketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, slotNumber])
  @@index([orderId, status])
  @@index([invitationId])
  @@map("ticket_slots")
}

model InvitationTicket {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  invitationId     String    @unique @map("invitation_id") @db.ObjectId
  manualEntryId    String    @map("manual_entry_id")
  qrPayload        String    @map("qr_payload")
  unlockAt         DateTime  @map("unlock_at")
  validatedAt      DateTime? @map("validated_at")
  consumptionCount Int?      @map("consumption_count")
  stayMinutes      Int?      @map("stay_minutes")
  createdAt        DateTime  @default(now()) @map("created_at")

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("invitation_tickets")
}

model UserPaymentMethod {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @map("user_id") @db.ObjectId
  providerToken  String          @map("provider_token")
  gateway        PaymentGateway? @default(stripe)
  brand          String
  lastFour       String   @map("last_four")
  cardholderName String   @map("cardholder_name")
  isDefault      Boolean  @default(true) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_payment_methods")
}
